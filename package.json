{
  "name": "offlinehub",
  "version": "1.0.0",
  "description": "Offline-first social app with walkie-talkie, local chat, and file sharing",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "install-all": "npm install",
    "dev": "concurrently \"npm --workspace=frontend run dev\" \"npm --workspace=backend run dev\"",
    "build": "npm --workspace=frontend run build && npm --workspace=backend run build",
    "start": "npm --workspace=backend start",
    "test": "npm workspaces run test",
    "lint": "npm workspaces run lint"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
