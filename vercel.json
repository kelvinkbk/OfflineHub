{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL",
      "default": "http://localhost:5000"
    },
    "NODE_ENV": {
      "default": "production"
    }
  },
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "git": {
    "scope": ["frontend/**", "backend/**", "package.json"]
  }
}
